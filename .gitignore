# .gitignore — Olive Street Scripts

# Secrets
.env

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
env/
venv/

# Generated outputs — ignored, keep only folder placeholders
output/logos/*
output/profiles/*
output/posts/*
output/fliers/*
output/archive/*

# Keep the output folder structure
!output/logos/.gitkeep
!output/profiles/.gitkeep
!output/posts/.gitkeep
!output/fliers/.gitkeep
!output/archive/.gitkeep

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors
.vscode/
*.swp
*.swo
